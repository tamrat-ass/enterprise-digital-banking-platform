{
  "info": {
    "name": "Enterprise Digital Banking Platform API - COMPLETE",
    "description": "Complete API collection with Authentication, User Management, and RBAC",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_postman_id": "enterprise-banking-api-complete",
    "version": "3.0.0"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000",
      "type": "string"
    },
    {
      "key": "authToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "userId",
      "value": "",
      "type": "string"
    },
    {
      "key": "roleId",
      "value": "",
      "type": "string"
    },
    {
      "key": "permissionId",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "🔐 Authentication",
      "item": [
        {
          "name": "Sign In",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  var jsonData = pm.response.json();",
                  "  pm.environment.set('authToken', jsonData.session.token);",
                  "  pm.environment.set('userId', jsonData.user.id);",
                  "  console.log('✅ Signed in as:', jsonData.user.name);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"ahadu@gmail.com\",\n  \"password\": \"TestPassword123!\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/signin",
              "protocol": "http",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "signin"]
            }
          }
        }
      ]
    },
    {
      "name": "👥 User Management",
      "item": [
        {
          "name": "Get All Users",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Cookie",
                "value": "authToken={{authToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/users",
              "protocol": "http",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users"]
            }
          }
        },
        {
          "name": "Get User by ID",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Cookie",
                "value": "authToken={{authToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/users/{{userId}}",
              "protocol": "http",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users", "{{userId}}"]
            }
          }
        },
        {
          "name": "Reset User Password",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Cookie",
                "value": "authToken={{authToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": \"{{userId}}\",\n  \"password\": \"NewPassword123!\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/users/reset-password",
              "protocol": "http",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users", "reset-password"]
            }
          }
        }
      ]
    },
    {
      "name": "🔑 RBAC - Roles Management",
      "item": [
        {
          "name": "Get All Roles",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  var jsonData = pm.response.json();",
                  "  if (jsonData.data && jsonData.data.length > 0) {",
                  "    pm.environment.set('roleId', jsonData.data[0].id);",
                  "    console.log('✅ Roles retrieved, first role ID saved');",
                  "  }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Cookie",
                "value": "authToken={{authToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/rbac/roles",
              "protocol": "http",
              "host": ["{{baseUrl}}"],
              "path": ["api", "rbac", "roles"]
            }
          }
        },
        {
          "name": "Get Role by ID",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Cookie",
                "value": "authToken={{authToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/rbac/roles/{{roleId}}",
              "protocol": "http",
              "host": ["{{baseUrl}}"],
              "path": ["api", "rbac", "roles", "{{roleId}}"]
            }
          }
        },
        {
          "name": "Create Role",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Cookie",
                "value": "authToken={{authToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Document Manager\",\n  \"description\": \"Can manage and approve documents\",\n  \"permissionIds\": []\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/rbac/roles",
              "protocol": "http",
              "host": ["{{baseUrl}}"],
              "path": ["api", "rbac", "roles"]
            }
          }
        },
        {
          "name": "Update Role",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Cookie",
                "value": "authToken={{authToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Document Manager Updated\",\n  \"description\": \"Can manage, approve, and delete documents\",\n  \"permissionIds\": []\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/rbac/roles/{{roleId}}",
              "protocol": "http",
              "host": ["{{baseUrl}}"],
              "path": ["api", "rbac", "roles", "{{roleId}}"]
            }
          }
        },
        {
          "name": "Delete Role",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Cookie",
                "value": "authToken={{authToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/rbac/roles/{{roleId}}",
              "protocol": "http",
              "host": ["{{baseUrl}}"],
              "path": ["api", "rbac", "roles", "{{roleId}}"]
            }
          }
        }
      ]
    },
    {
      "name": "🔐 RBAC - Permissions Management",
      "item": [
        {
          "name": "Get All Permissions",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  var jsonData = pm.response.json();",
                  "  if (jsonData.data && jsonData.data.length > 0) {",
                  "    pm.environment.set('permissionId', jsonData.data[0].id);",
                  "    console.log('✅ Permissions retrieved, first permission ID saved');",
                  "  }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Cookie",
                "value": "authToken={{authToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/rbac/permissions",
              "protocol": "http",
              "host": ["{{baseUrl}}"],
              "path": ["api", "rbac", "permissions"]
            }
          }
        },
        {
          "name": "Get Permissions by Module",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Cookie",
                "value": "authToken={{authToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/rbac/permissions?groupBy=module",
              "protocol": "http",
              "host": ["{{baseUrl}}"],
              "path": ["api", "rbac", "permissions"],
              "query": [
                {
                  "key": "groupBy",
                  "value": "module"
                }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "👤 RBAC - Assign Roles to Users",
      "item": [
        {
          "name": "Assign Role to User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Cookie",
                "value": "authToken={{authToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": \"{{userId}}\",\n  \"roleId\": \"{{roleId}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/rbac/user-roles",
              "protocol": "http",
              "host": ["{{baseUrl}}"],
              "path": ["api", "rbac", "user-roles"]
            }
          }
        },
        {
          "name": "Get User Roles",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Cookie",
                "value": "authToken={{authToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/rbac/user-roles/{{userId}}",
              "protocol": "http",
              "host": ["{{baseUrl}}"],
              "path": ["api", "rbac", "user-roles", "{{userId}}"]
            }
          }
        }
      ]
    },
    {
      "name": "📄 Documents",
      "item": [
        {
          "name": "Get All Documents",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Cookie",
                "value": "authToken={{authToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/documents",
              "protocol": "http",
              "host": ["{{baseUrl}}"],
              "path": ["api", "documents"]
            }
          }
        }
      ]
    },
    {
      "name": "🏥 Health",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/api/health",
          "protocol": "http",
          "host": ["{{baseUrl}}"],
          "path": ["api", "health"]
        }
      }
    }
  ]
}
