# PostgreSQL Configuration
DATABASE_URL=postgresql://postgres:4840@localhost:5432/ahadufile

# Connection Pool Configuration (Drizzle ORM)
# Increased from previous aggressive settings for production load
DB_POOL_MAX=20
DB_IDLE_TIMEOUT=30
DB_CONNECT_TIMEOUT=10

# Connection Pool Configuration (Better Auth)
# Separate pool for authentication to prevent auth bottlenecks
DB_AUTH_POOL_MAX=10
DB_AUTH_POOL_MIN=1
DB_AUTH_IDLE_TIMEOUT=30000
DB_AUTH_CONNECT_TIMEOUT=5000

# Next Auth (if applicable)
NEXTAUTH_SECRET=your-secret-key-here
NEXTAUTH_URL=http://localhost:3000









